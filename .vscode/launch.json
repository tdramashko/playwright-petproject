{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Playwright: run all tests",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "args": ["playwright", "test", "--reporter=list"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Playwright: debug all tests",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "args": ["playwright", "test", "--debug"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PWDEBUG": "1"
      }
    },
    {
      "name": "Playwright: debug current file",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "args": ["playwright", "test", "${fileBasename}", "--debug"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PWDEBUG": "1"
      }
    },
    {
      "name": "Playwright: open UI mode",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "args": ["playwright", "test", "--ui"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
